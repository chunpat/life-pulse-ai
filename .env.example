# 环境变量配置示例
# 复制此文件为 .env 并填入你的实际 API Key

# AI 模型配置
# 后端默认在存在 MINIMAX_API_KEY 时使用 MiniMax，否则回退到 Qwen。
LLM_PROVIDER=minimax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_FORMAT=openai

# 如需切回 Qwen，可设置 LLM_PROVIDER=qwen 并填写下面几项
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-plus
QWEN_ENABLE_THINKING=false

# Web/PWA 运行时可选 API 基址；留空时浏览器开发环境继续使用 Vite /api 代理
VITE_API_BASE_URL=

# iOS 原生容器建议显式配置后端地址，例如 http://192.168.1.10:5002
VITE_NATIVE_API_BASE_URL=

# Apple 登录客户端 ID；原生 iOS 默认可直接使用 Capacitor appId
VITE_APPLE_CLIENT_ID=ai.lifepulse.app

# Web/调试桥接时可选；原生 iOS 插件当前不会使用该地址
VITE_APPLE_REDIRECT_URI=
